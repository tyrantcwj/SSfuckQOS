# ===== Shared (server + client must match) =====
SS_PASSWORD=change_me_to_a_strong_password
SS_METHOD=chacha20-ietf-poly1305
SS_TIMEOUT=300
V2RAY_PATH=/nas-sync

# Home LAN for interconnectivity (covers 10.0.0.0 - 10.0.254.x)
LAN_CIDRS=10.0.0.0/16

# ===== Server =====
SERVER_PORT=80
SERVER_BIND=0.0.0.0
# Shown in admin export / client configs
PUBLIC_HOST=your.ddns.example.com
ADMIN_PORT=8080
ADMIN_PASSWORD=change_me_admin_password

# ===== Client =====
REMOTE_SERVER=your.ddns.example.com
REMOTE_PORT=80
# Optional: only if HTTP Host must differ from REMOTE_SERVER (e.g. CDN)
# V2RAY_HOST=your.ddns.example.com
LOCAL_SOCKS_PORT=1080
LOCAL_HTTP_PORT=8118
